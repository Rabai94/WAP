SUPABASE_URL=
# Optional fallback if SUPABASE_URL is not set.
EXPO_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Edge Function setting. May also be a template containing {token}.
# Example: https://app.example.com/credentials/verify
CREDENTIAL_VERIFICATION_BASE_URL=

# Public app route base used when copying/sharing verification links on native.
EXPO_PUBLIC_CREDENTIAL_VERIFICATION_BASE_URL=

# Optional: use local GeoNames zip files instead of downloading them.
GEONAMES_DE_DUMP_ZIP=
GEONAMES_DE_POSTAL_ZIP=
GEONAMES_CACHE_DIR=.cache/geonames

# Optional import tuning.
LOCATIONS_IMPORT_BATCH_SIZE=500
